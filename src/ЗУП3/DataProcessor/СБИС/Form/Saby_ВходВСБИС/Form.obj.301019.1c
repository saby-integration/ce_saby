&НаКлиенте
перем context_params;

//События формы и элементов формы
&НаСервере
Функция ПрочитатьНастройки()
	ПараметрыПодключения = Saby_НастройкиСервер.ПрочитатьНастройкиПодключения("param");
	Если ТипЗнч(ПараметрыПодключения) = Тип("Структура") Тогда
		//Заполним элементы формы данными из настроек
		ПараметрыПодключения.Свойство("password", Пароль);
		ПараметрыПодключения.Свойство("login", Логин);
		ПараметрыПодключения.Свойство("api_url", Сервер);
		Если ПустаяСтрока(Сервер)Тогда
			Сервер = Элементы.Сервер.СписокВыбора.Получить(0).Значение;
		КонецЕсли;
		Элементы.Подключение.СписокВыбора.Очистить();
		ConnectionId = "";
		ПараметрыПодключения.Свойство("ConnectionId", ConnectionId);
		Элементы.Подключение.СписокВыбора.Добавить(ConnectionId);
		Подключение	= ConnectionId;
	Иначе
		//Приведем к значению - Неопределено
		ПараметрыПодключения = Неопределено;
		Сервер = Элементы.Сервер.СписокВыбора.Получить(0).Значение;
	КонецЕсли;
	Возврат ПараметрыПодключения;
	//Saby_НастройкиСервер.НачальнаяИнициализация();
КонецФункции

&НаСервере
Процедура ЗаписатьНастройки(НастройкиПодключения)
	Saby_НастройкиСервер.ЗаписатьНастройкиПодключения("param", НастройкиПодключения);
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	АвторизацииУспешна	= Ложь;
КонецПроцедуры

