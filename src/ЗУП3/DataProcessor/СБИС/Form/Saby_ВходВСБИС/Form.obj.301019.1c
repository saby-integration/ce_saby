//Авторизуется по логину/паролю	

&НаСервере
Процедура УстановитьСостояниеСоединения( ТекстСтутусПодключения, УспешнаяОперация = Истина )
	
	СтатусПодключения	= ТекстСтутусПодключения;
	Если УспешнаяОперация Тогда
		Элементы.СтатусПодключения.ЦветТекста	= WebЦвета.ТемноЗеленый;
	Иначе
		Элементы.СтатусПодключения.ЦветТекста	= WebЦвета.Томатный;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СкрытьСтутусПодключения()
	Элементы.СтатусПодключения.Видимость	= Ложь;
КонецПроцедуры

&НаСервере
Функция Авторизоваться(ПараметрыАвторизации = Неопределено)
	
	ПараметрыАвторизации			= Новый Структура("login,password,url,api_url");
	ПараметрыАвторизации.login		= Логин;
	ПараметрыАвторизации.password	= Пароль;							//1				//2
	ПараметрыАвторизации.url		= СтрЗаменить( СтрЗаменить(Сервер, "https://", ""), "http://", ""); //выпиливаем протокол
	ПараметрыАвторизации.api_url	= Сервер;
	
	ТранспортСБИС					= Обработки.СБИС.Создать();
	ПараметрыАвторизации.Вставить("session", Неопределено);
	Попытка
		СессияИД = ТранспортСБИС.local_helper_auth_by_login(ПараметрыАвторизации, Неопределено );
		ПараметрыАвторизации.Вставить("session", СессияИД);
	Исключение
		ИнфОбОшибке = ИнформацияОбОшибке();
	КонецПопытки;
	
 	Возврат (ТипЗнч(ПараметрыАвторизации.session) = Тип("Строка") и СтрДлина(ПараметрыАвторизации.session) = 39);
КонецФункции

