&НаСервере
Функция ПолучитьСсылкуДляКадровыеДокументы() Экспорт 
	context_params = Saby_НастройкиСервер.ПрочитатьНастройкиПодключения("param");
	УРЛСТикетом = СформироватьУРЛСТикетом(context_params.api_url+"/page/cadres?", "");
	Возврат УРЛСТикетом;
КонецФункции


Функция ПолучитьОбъектыПоUID(мОбъекты) Экспорт
		
	tUID = Новый ТаблицаЗначений;
	tUID.Колонки.Добавить("UID", Новый ОписаниеТипов("Строка") );
	Для Каждого Объект Из мОбъекты Цикл
		НовСтрока = tUID.Добавить();
		НовСтрока.UID = Объект["ИдСБИС"];
	КонецЦикла;
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	| UIDs.UID КАК UID
	|ПОМЕСТИТЬ ВР_UID
	|ИЗ
	| &мUID КАК UIDs
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	| ВР_UID.UID КАК UID,
	| ЕСТЬNULL(СД.Объект, НЕОПРЕДЕЛЕНО) КАК Объект,
	| ЕСТЬNULL(СД.Объект.Проведен, НЕОПРЕДЕЛЕНО) КАК Проведен
	|ИЗ
	| ВР_UID КАК ВР_UID
	| ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.Saby_Состояние.СрезПоследних КАК СД
	| ПО ВР_UID.UID = СД.UID";

	Запрос.Параметры.Вставить("мUID", tUID);
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Результат =  Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("ИдСБИС", Новый ОписаниеТипов("Строка") );
	Результат.Колонки.Добавить("ИдИС", Новый ОписаниеТипов("Строка") );
	Результат.Колонки.Добавить("ИмяИС", Новый ОписаниеТипов("Строка") );
	Результат.Колонки.Добавить("_Представление", Новый ОписаниеТипов("Строка") );
	Результат.Колонки.Добавить("Проведен", Новый ОписаниеТипов("Булево") );
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		НовСтрока = Результат.Добавить();
		НовСтрока.ИдСБИС = ВыборкаДетальныеЗаписи.UID;
		НовСтрока.Проведен = ВыборкаДетальныеЗаписи.Проведен;
		ПолучитьAPI3СсылкуИзСсылкиНаОбъект(ВыборкаДетальныеЗаписи.Объект, НовСтрока);
	КонецЦикла;
	Возврат Результат;
КонецФункции

Функция ПолучитьAPI3СсылкуИзСсылкиНаОбъект(СсылкаНаОбъект, API3Объект = Неопределено)
	Если Не ЗначениеЗаполнено(СсылкаНаОбъект) Тогда
		Возврат неопределено;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(API3Объект) Тогда
		API3Объект = Новый Структура("ИдИС, ИмяИС, _Представление");
	КонецЕсли;
	ТипЗначения = ТипЗнч(СсылкаНаОбъект);
	ОбъектМетаданных = Метаданные.НайтиПоТипу(ТипЗначения);
	Если ОбъектМетаданных <> Неопределено Тогда
		Если Метаданные.Справочники.Содержит(ОбъектМетаданных) Тогда
			ТипМетаданных = "Справочники";
			API3Объект["ИдИС"] = XMLСтрока(СсылкаНаОбъект.УникальныйИдентификатор());
		ИначеЕсли Метаданные.Документы.Содержит(ОбъектМетаданных) Тогда
			ТипМетаданных = "Документы";
			API3Объект["ИдИС"] = XMLСтрока(СсылкаНаОбъект.УникальныйИдентификатор());
		ИначеЕсли Метаданные.Перечисления.Содержит(ОбъектМетаданных) Тогда
			ТипМетаданных = "Перечисления";
			API3Объект["ИдИС"] = XMLСтрока(СсылкаНаОбъект);
		КонецЕсли;
		API3Объект["ИмяИС"] = ТипМетаданных+"."+ОбъектМетаданных.Имя;
		API3Объект["_Представление"] = СокрЛП(СсылкаНаОбъект);
	КонецЕсли;
	Возврат API3Объект;
	
КонецФункции
	